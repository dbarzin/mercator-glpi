#!/usr/bin/env php
<?php

define('LARAVEL_START', microtime(true));

/*
|--------------------------------------------------------------------------
| Raise the memory limit for this CLI run
|--------------------------------------------------------------------------
|
| A full sync loads whole GLPI collections into memory (pagination now
| retrieves collections beyond 1000 items, cf. issue #12 follow-up) and the
| default CLI php.ini memory_limit (often 128M, inherited from the web SAPI
| config) can be too low for larger GLPI installs. This process only runs
| batch synchronisations, never serves web requests, so raising its own
| limit here is safe and avoids requiring every install to edit php.ini.
| Never lowers an already-higher (or unlimited, "-1") admin-configured value.
|
*/

$minMemoryLimit = '512M';
$currentMemoryLimit = ini_get('memory_limit');

if ($currentMemoryLimit !== '-1' && parseIniBytes($currentMemoryLimit) < parseIniBytes($minMemoryLimit)) {
    ini_set('memory_limit', $minMemoryLimit);
}

function parseIniBytes(string $value): int
{
    $value = trim($value);
    $unit = strtolower(substr($value, -1));
    $number = (int) $value;

    return match ($unit) {
        'g' => $number * 1024 * 1024 * 1024,
        'm' => $number * 1024 * 1024,
        'k' => $number * 1024,
        default => $number,
    };
}

/*
|--------------------------------------------------------------------------
| Register The Auto Loader
|--------------------------------------------------------------------------
|
| Composer provides a convenient, automatically generated class loader
| for our application. We just need to utilize it! We'll require it
| into the script here so that we do not have to worry about the
| loading of any our classes "manually". Feels great to relax.
|
*/

$autoloader = require file_exists(__DIR__.'/vendor/autoload.php') ?  __DIR__.'/vendor/autoload.php' : __DIR__.'/../../autoload.php';

$app = require_once __DIR__.'/bootstrap/app.php';

/*
|--------------------------------------------------------------------------
| Run The Artisan Application
|--------------------------------------------------------------------------
|
| When we run the console application, the current CLI command will be
| executed in this console and the response sent back to a terminal
| or another output device for the developers. Here goes nothing!
|
*/

$kernel = $app->make(Illuminate\Contracts\Console\Kernel::class);

$status = $kernel->handle(
    $input = new Symfony\Component\Console\Input\ArgvInput,
    new Symfony\Component\Console\Output\ConsoleOutput
);

/*
|--------------------------------------------------------------------------
| Shutdown The Application
|--------------------------------------------------------------------------
|
| Once Artisan has finished running, we will fire off the shutdown events
| so that any final work may be done by the application before we shut
| down the process. This is the last thing to happen to the request.
|
*/

$kernel->terminate($input, $status);

exit($status);
