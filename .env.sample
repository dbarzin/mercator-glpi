APP_NAME="Mercator GLPI Connector"
APP_ENV=production
APP_DEBUG=false

# ── GLPI ──────────────────────────────────────────────────────────────────────
GLPI_URL=http://localhost:8080
GLPI_APP_TOKEN=your_app_token_here
GLPI_USER_TOKEN=your_user_token_here

# Entité GLPI à synchroniser (vide = toutes les entités)
GLPI_ENTITY_ID=

# Filtrage par statut GLPI (states_id) — IDs séparés par virgules ; vide = tous
GLPI_ALLOWED_STATES=
GLPI_ALLOWED_STATES_COMPUTERS=
GLPI_ALLOWED_STATES_PHONES=
GLPI_ALLOWED_STATES_PERIPHERALS=
GLPI_ALLOWED_STATES_NETWORK_EQUIPMENT=
GLPI_ALLOWED_STATES_RACKS=

# Routage des Computer par sous-type (IDs ou noms de computertypes GLPI)
# Vide = tous les Computer ; pour logical_servers/physical_servers vide = désactivé
GLPI_COMPUTER_TYPES_WORKSTATIONS=
GLPI_COMPUTER_TYPES_LOGICAL_SERVERS=
GLPI_COMPUTER_TYPES_PHYSICAL_SERVERS=

# Routage des NetworkEquipment par sous-type (IDs ou noms de networkequipmenttypes GLPI)
# Vide pour SWITCHES = tous les NetworkEquipment non routés ailleurs (comportement historique)
# Vide pour les autres = désactivé (opt-in explicite)
GLPI_NETWORK_DEVICE_TYPES_SWITCHES=
GLPI_NETWORK_DEVICE_TYPES_ROUTERS=
GLPI_NETWORK_DEVICE_TYPES_WIFI_TERMINALS=
GLPI_NETWORK_DEVICE_TYPES_PHYSICAL_SECURITY_DEVICES=
GLPI_NETWORK_DEVICE_TYPES_STORAGE_DEVICES=

# Filtrage des Domain par type (IDs ou noms de domaintypes GLPI) — vide = tous types acceptés
GLPI_DOMAIN_TYPES=

# Filtrage des Software par catégorie (IDs ou noms de softwarecategories GLPI) — vide = toutes catégories acceptées
GLPI_SOFTWARE_CATEGORIES=

# ── Mercator ──────────────────────────────────────────────────────────────────
MERCATOR_URL=http://localhost:8000
MERCATOR_LOGIN=admin@admin.com
MERCATOR_PASSWORD=password

# ── Synchronisation ───────────────────────────────────────────────────────────
SYNC_DRY_RUN=false

# ── Logs ──────────────────────────────────────────────────────────────────────
# Niveaux : debug, info, warning, error
# En mode debug, les URLs, payloads et réponses HTTP complètes sont journalisés.
LOG_LEVEL=info
